<!DOCTYPE html>
<html>
  <head>
    <title></title>
	<link rel='stylesheet' href='/stylesheets/common.css' />
	<link rel='stylesheet' href='/stylesheets/right_style.css' />
  </head>
  <body>
    <div class="main">
		<div class="info">
			<div class="info-group">
				<h3>供应商号:<%= infolist.sno %><h3>
			</div>
			<div class="info-group">
				<h3>姓名:<%= infolist.sname %><h3>
			</div>
			<div class="info-group">
				<h3>地址:<%= infolist.address %><h3>
			</div>
			<div class="info-group">
				<h3>电话:<%= infolist.phone %><h3>
			</div>
			<div class="info-group">
				<h3>用户名:<%= infolist.userName %><h3>
			</div>
		</div>
		<button class="quit_s">修改信息</button>
	</div>
	<script src="/javascripts/jquery.js"></script>
	<script>
		$(function(){
			$('.quit_s').click(function(){
				window.location.href = "/information/modify_s?userName=<%= userName %>";
			})
		})
	</script>
  </body>
</html>
