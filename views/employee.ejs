<!DOCTYPE html>
<html>
  <head>
    <title>职工表</title>
	<meta charset="utf-8">
	<link rel='stylesheet' href='/stylesheets/bootstrap.min.css' />
	<link rel='stylesheet' href='/stylesheets/common.css' />
	<link rel='stylesheet' href='/stylesheets/table_style.css' />
  </head>
  <body>
    <div class="container">
		<div class="main">
			<div class="select">
				<form action="/warehouse/employee" method="post">
					<select name="selectVal">
							<option value="current">显示当前仓库员工</option>
							<option value="other">显示尚未分配领导员工</option>
					</select>
					<div class="search">
						<span><%= listname %></span>
						<input type="text" name="wno" value="<%= wno %>" style="display: none;" />
						<input type="text" name="wmno" value="<%= wmno %>" style="display: none;" />
						<button class="searchBtn">
							<img src="/images/search.png" width="25px" height="25px">
						</button>
					</div>
				</form>
			</div>
			<div class="content">
				<table class="table">
					<thead>
						<tr>
							<th>职工号</th>
							<th>姓名</th>
							<th>职称</th>
							<th>领导职工号</th>
							<th>从属仓库号</th>
							<th>用户名</th>
							<th>操作</th>
						</tr>
					</thead>
					<tbody>
						<% tablelist.forEach(function(item){ %>
						<tr>
							<td><%= item.wmno %></td>
							<td><%= item.wname %></td>
							<td><%= item.profession %></td>
							<td><%= item.leader %></td>
							<td><%= item.wno %></td>
							<td><%= item.userName %></td>
							<td>
								<img src="/images/hire.png" class="hire" width="25px" height="25px" data-wmno="<%= item.wmno %>" data-leader="<%= item.leader %>">
								<img src="/images/fire.png" class="del" width="25px" height="25px" data-wmno="<%= item.wmno %>" data-leader="<%= item.leader %>">
							</td>
						</tr>
						<% }) %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
	<div class="dialog isDialog"></div>
	<div class="dialog-wrap isDialog">
		<div class="dialog-header">
			<h3>添加仓库</h3>
			<div class="close">
				<img src="/images/close.png" style="width:25px;height:25px">
			</div>
		</div>
		<form action="/addWare" method="post">
			<div>
				<p>仓库号(唯一标识，不能重复)</p>
				<p>
					<input type="text" class="form-control" name="wno" />
				</p>
			</div>
			<div>
				<p>面积(m^2)</p>
				<p>
					<input type="text" class="form-control" name="square" />
				</p>
			</div>
			<div>
				<p>联系电话</p>
				<p>
					<input type="text" class="form-control" name="phone" />
				</p>
			</div>		
			<div class="dialog-submit">
				<button class="determine">确定</button>
			</div>
		</form>
		<div class="dialog-ware-add">
			<button class="cancel">取消</button>	
		</div>
	</div>

	<div class="dialog isHire"></div>
	<div class="dialog-wrap isHire">
		<div class="dialog-header">
			<h3>确定添加从属关系?</h3>
			<div class="close">
				<img src="/images/close.png" style="width:25px;height:25px">
			</div>
			<div class="dialog-footer">
				<button class="determine determineHire">确定</button>
				<button class="cancel">取消</button>
			</div>			
		</div>
	</div>
	
	<div class="dialog isDelete"></div>
	<div class="dialog-wrap isDelete">
		<div class="dialog-header">
			<h3>确定取消从属关系?</h3>
			<div class="close">
				<img src="/images/close.png" style="width:25px;height:25px">
			</div>
			<div class="dialog-footer">
				<button class="determine determineDel">确定</button>
				<button class="cancel">取消</button>
			</div>			
		</div>
	</div>

  <script src="/javascripts/jquery.js"></script>
  <script>
	$(function(){
		var wmno = '';
		var leader = '';
		var updateHtml = '';
		//显示表单
		$('#addBtn').click(function(){
			$('.isDialog').show();
		})
		//隐藏表单
		$('.close,.cancel').click(function(){
			$('.isDialog').hide();
		})
		//点击删除
		$('.hire').click(function(){
			wmno = $(this).data('wmno')
			leader = $(this).data('leader');
			$('.isHire').show();
		})
		
		$('.del').click(function(){
			wmno = $(this).data('wmno')
			leader = $(this).data('leader');
			$('.isDelete').show();
		})
		//隐藏删除
		$('.close,.cancel').click(function(){
			$('.isHire').hide();
		})
		
		$('.close,.cancel').click(function(){
			$('.isDelete').hide();
		})
		//点击确定删除
		$('.determineHire').click(function(){
			window.location.href = `/updateWare/hire?wmno=${wmno}&leader=${leader}&id=<%= wmno %>`;
		})
		
		$('.determineDel').click(function(){
			window.location.href = `/updateWare/fire?wmno=${wmno}&leader=${leader}&id=<%= wmno %>`;
		})
		
		//点击修改操作
		$('.specific').click(function(){
			var spPno = $(this).data('pno');
			var spSno = $(this).data('sno');
			window.location.href = `/information/details?pno=${spPno}&sno=${spSno}`;
		})
		
		//取消修改操作
		$('body').on('click','.close,.cancel',function(){
			$('.isUpdate').hide();
		})
	})
  </script>
  </body>
</html>