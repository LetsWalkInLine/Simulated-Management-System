<!DOCTYPE html>
<html>
  <head>
    <title></title>
	<link rel='stylesheet' href='/stylesheets/common.css' />
	<link rel='stylesheet' href='/stylesheets/right_style.css' />
  </head>
  <body>
    <div class="main">
		<div class="info_w">
			<div class="info-group">
				<h3>职工号:<%= infolist.wmno %><h3>
			</div>
			<div class="info-group">
				<h3>姓名:<%= infolist.wname %><h3>
			</div>
			<div class="info-group">
				<h3>职称:<%= infolist.profession %><h3>
			</div>
			<div class="info-group">
				<h3>领导职工号:<%= infolist.leader %><h3>
			</div>
			<div class="info-group">
				<h3>从属仓库号:<%= infolist.wno %><h3>
			</div>
			<div class="info-group">
				<h3>用户名:<%= infolist.userName %><h3>
			</div>
		</div>
		<button class="quit_w">修改信息</button>
	</div>
	<script src="/javascripts/jquery.js"></script>
	<script>
		$(function(){
			$('.quit_w').click(function(){
				window.location.href = "/information/modify_w?userName=<%= userName %>";
			})
		})
	</script>
  </body>
</html>
