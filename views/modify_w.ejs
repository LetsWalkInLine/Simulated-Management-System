<!DOCTYPE html>
<html>
  <head>
    <title></title>
	<link rel='stylesheet' href='/stylesheets/common.css' />
	<link rel='stylesheet' href='/stylesheets/right_style.css' />
  </head>
  <body>
    <div class="main">
		<h3 style="color: red; font-size: 32px;">请完善个人信息<h3>
		<form action="/information/modify_w" method="post">
			<div class='form-group'>
				<label>职工号</label>
				<input type="text" name="wmno">
			</div>
			<div class='form-group'>
				<label>姓名</label>
				<input type="text" name="wname">
			</div>
			<div class='form-group'>
				<label>职称</label>
				<input type="text" name="profession">
			</div>
			<div class='form-group'>
				<label>从属仓库号</label>
				<select name="wno">
					<% wnolist.forEach(function(item){ %>
						<option value="<%= item.wno %>"><%= item.wno %></option>
					<% }) %>
				</select>
			</div>
			<input type="text" name="userName" value="<%= userName %>" style="display: none;">
			<input type="submit" value="修改完成">
		</form>
		<button class="quit_w">退出修改</button>
	</div>
	<script src="/javascripts/jquery.js"></script>
	<script>
		$(function(){
			$('.quit_w').click(function(){
				window.location.href = "/information/wm?userName=<%= userName %>";
			})
		})
	</script>
  </body>
</html>
